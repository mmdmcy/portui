ID=interactive-echo
TITLE=Interactive Echo
DESCRIPTION=Smoke-test direct terminal I/O mode without requiring user input.
INTERACTIVE=true
TIMEOUT_SECONDS=0
CWD={{projectDir}}
POSIX_PROGRAM=sh
POSIX_ARGS=-c|printf '%s\n' 'interactive=true'
WINDOWS_PROGRAM=powershell
WINDOWS_ARGS=-NoProfile|-Command|Write-Output 'interactive=true'

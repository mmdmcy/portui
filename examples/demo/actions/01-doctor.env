ID=doctor
TITLE=Shell Doctor
DESCRIPTION=Verify that the native shell can run a simple diagnostic.
TIMEOUT_SECONDS=15
POSIX_PROGRAM=sh
POSIX_ARGS=-c|printf 'os=%s\nshell=sh\ncwd=%s\n' '{{os}}' "$(pwd)"
WINDOWS_PROGRAM=powershell
WINDOWS_ARGS=-NoProfile|-Command|Write-Output ('os=' + $env:OS); Write-Output ('shell=PowerShell'); Write-Output ('cwd=' + (Get-Location).Path)

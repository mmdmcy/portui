ID=show-home
TITLE=Show Home Directory
DESCRIPTION=Demonstrate built-in variable expansion and per-OS path separators.
TIMEOUT_SECONDS=10
POSIX_PROGRAM=sh
POSIX_ARGS=-c|printf 'home=%s\npathSep=%s\nlistSep=%s\n' '{{home}}' '{{pathSep}}' '{{listSep}}'
WINDOWS_PROGRAM=powershell
WINDOWS_ARGS=-NoProfile|-Command|Write-Output ('home={{home}}'); Write-Output ('pathSep={{pathSep}}'); Write-Output ('listSep={{listSep}}')

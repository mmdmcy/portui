ID=doctor
TITLE=Alpha Doctor
DESCRIPTION=Print workspace-aware details for the alpha project.
TIMEOUT_SECONDS=20
CWD={{projectDir}}
POSIX_PROGRAM=sh
POSIX_ARGS=-c|printf '%s\n' 'alpha={{projectId}}' 'project={{projectDir}}' 'workspace={{workspaceDir}}'
WINDOWS_PROGRAM=powershell
WINDOWS_ARGS=-NoProfile|-Command|Write-Output 'alpha={{projectId}}'; Write-Output 'project={{projectDir}}'; Write-Output 'workspace={{workspaceDir}}'
